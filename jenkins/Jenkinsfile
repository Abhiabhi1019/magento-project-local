pipeline {
    agent any

    options {
        timeout(time: 90, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        COMPOSE_PROJECT_NAME = "magento-project-local"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }



        stage('Start Containers') {
            steps {
                script {
                    def hostJenkinsHome = sh(script: "docker inspect \$(hostname) --format '{{ range .Mounts }}{{ if eq .Destination \"/var/jenkins_home\" }}{{ .Source }}{{ end }}{{ end }}'", returnStdout: true).trim()
                    def workspaceSuffix = env.WORKSPACE.replace('/var/jenkins_home', '')
                    env.WORKSPACE_HOST = hostJenkinsHome + workspaceSuffix

                    sh '''
                    docker compose down || true
                    docker compose up -d --build
                    '''
                }
            }
        }

        stage('Fix Container Permissions') {
            steps {
                sh '''
                docker compose exec -u root php bash -c "
                chown -R www-data:www-data /var/www/html
                chmod -R 755 /var/www/html
                "
                '''
            }
        }

        stage('Composer Install') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html
                composer install --no-interaction --prefer-dist --no-progress
                "
                '''
            }
        }

        stage('Magento Setup') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html

                php bin/magento setup:upgrade || true
                php bin/magento cache:flush || true
                "
                '''
            }
        }

        stage('Verify') {
            steps {
                sh 'docker ps'
            }
        }
    }

    post {
        always {
            sh '''
            docker compose exec -u root php bash -c "
            chown -R 1000:1000 /var/www/html
            " || true
            '''
        }
    }
}
