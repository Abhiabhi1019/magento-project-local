pipeline {
    agent any

    options {
        timeout(time: 90, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        COMPOSE_PROJECT_NAME = "magento-project-local"
        DOCKER_GID = sh(script: "stat -c '%g' /var/run/docker.sock", returnStdout: true).trim()
    }

    stages {

        // ────────────────────────────────────────────────────────────────────
        stage('Checkout Code') {
        // ────────────────────────────────────────────────────────────────────
            steps {
                git branch: 'main', url: 'https://github.com/Abhiabhi1019/magento-project-local.git'
            }
        }

        // ────────────────────────────────────────────────────────────────────
        stage('Debug Workspace') {
        // WHY THIS STAGE EXISTS:
        // Jenkins runs inside Docker (DooD — Docker outside of Docker).
        // Volume bind-mounts in docker-compose.yml are resolved by the HOST
        // Docker daemon, not by the Jenkins container. So paths like ./magento
        // refer to a path on the HOST filesystem — which is the jenkins-data
        // Docker volume, NOT the Jenkins container's internal filesystem.
        //
        // This stage:
        //   1) Shows exactly what was checked out (debugging aid)
        //   2) Computes WORKSPACE_HOST — the real HOST path of this workspace
        //   3) Writes WORKSPACE_HOST to .env so docker-compose can use it
        // ────────────────────────────────────────────────────────────────────
            steps {
                script {
                    echo "=== DEBUG WORKSPACE ==="
                    echo "Workspace (inside container): ${env.WORKSPACE}"

                    sh 'echo "--- Top-level workspace contents ---" && ls -la'
                    sh 'echo "--- magento/ directory ---" && ls -la magento/ 2>/dev/null || echo "WARNING: magento/ not found in workspace"'
                    sh 'echo "--- docker/ directory ---" && ls -la docker/ 2>/dev/null || echo "WARNING: docker/ not found"'

                    // ── Compute HOST path of this Jenkins workspace ─────────
                    // Jenkins home (/var/jenkins_home) is a named Docker volume.
                    // On the HOST it lives at:
                    //   /var/lib/docker/volumes/<project>_jenkins-data/_data
                    // We ask the Docker daemon where it mounted /var/jenkins_home,
                    // then reconstruct the workspace path from that.
                    def hostJenkinsHome = sh(
                        script: """
                            docker inspect \$(hostname) \
                              --format '{{ range .Mounts }}{{ if eq .Destination "/var/jenkins_home" }}{{ .Source }}{{ end }}{{ end }}'
                        """,
                        returnStdout: true
                    ).trim()

                    if (!hostJenkinsHome) {
                        error("Could not determine HOST path of /var/jenkins_home. Is the Jenkins container running with a named volume?")
                    }

                    // WORKSPACE inside container = /var/jenkins_home/workspace/JOB_NAME
                    // Strip the /var/jenkins_home prefix to get the suffix
                    def workspaceSuffix = env.WORKSPACE.replace('/var/jenkins_home', '')
                    env.WORKSPACE_HOST = hostJenkinsHome + workspaceSuffix

                    echo "Jenkins home (host):  ${hostJenkinsHome}"
                    echo "Workspace (host):     ${env.WORKSPACE_HOST}"

                    // Write to .env so docker-compose picks it up automatically
                    sh """
                        echo "WORKSPACE_HOST=${env.WORKSPACE_HOST}" > .env
                        echo "DOCKER_GID=${env.DOCKER_GID}"         >> .env
                        echo "--- .env written ---"
                        cat .env
                    """
                }
            }
        }

        // ────────────────────────────────────────────────────────────────────
        stage('Validate Files') {
        // Verify every required file exists in the workspace BEFORE running
        // docker compose. Missing files cause cryptic OCI / mount errors.
        // ────────────────────────────────────────────────────────────────────
            steps {
                sh '''
                set -e
                echo "=== VALIDATE FILES ==="

                ERRORS=0

                check_file() {
                    if [ ! -f "$1" ]; then
                        echo "❌ MISSING FILE : $1"
                        ERRORS=$((ERRORS+1))
                    elif [ -d "$1" ]; then
                        echo "❌ IS A DIRECTORY: $1  (Docker created this — remove it and re-commit the file)"
                        ERRORS=$((ERRORS+1))
                    else
                        echo "✅ OK: $1"
                    fi
                }

                check_dir() {
                    if [ ! -d "$1" ]; then
                        echo "❌ MISSING DIR : $1"
                        ERRORS=$((ERRORS+1))
                    else
                        echo "✅ OK: $1/"
                    fi
                }

                # ── Required config files ────────────────────────────────────
                check_file "docker/nginx/default.conf"
                check_file "docker/varnish/default.vcl"
                check_file "scripts/generate-ssl.sh"
                check_file "docker/php/Dockerfile"
                check_file "jenkins/Dockerfile"
                check_file "docker-compose.yml"

                # ── Required Magento source files ────────────────────────────
                check_file "magento/composer.json"
                check_file "magento/composer.lock"
                check_dir  "magento/app"
                check_dir  "magento/bin"
                check_dir  "magento/pub"

                echo ""
                if [ "$ERRORS" -gt 0 ]; then
                    echo "❌ $ERRORS validation error(s) found. Fix before deploying."
                    exit 1
                fi

                echo "✅ All required files present."
                echo "Docker version:   $(docker --version)"
                echo "Compose version:  $(docker compose version)"
                echo "=== VALIDATION PASSED ==="
                '''
            }
        }

        // ────────────────────────────────────────────────────────────────────
        stage('Generate SSL') {
        // ────────────────────────────────────────────────────────────────────
            steps {
                sh 'chmod +x scripts/generate-ssl.sh && ./scripts/generate-ssl.sh'
            }
        }

        // ────────────────────────────────────────────────────────────────────
        stage('Start Containers') {
        // Starts only the 5 app services. Jenkins is excluded via profiles:[ci]
        // to prevent the "port 8082 already allocated" error.
        // WORKSPACE_HOST in .env makes docker-compose bind-mount the workspace
        // magento/ directory directly — no docker cp needed.
        // ────────────────────────────────────────────────────────────────────
            steps {
                sh '''
                set -e
                echo "=== START CONTAINERS ==="
                echo "WORKSPACE_HOST = ${WORKSPACE_HOST}"

                # Tear down app stack only (never touches jenkins container)
                docker compose down --remove-orphans || true

                # Build only app images
                docker compose build nginx php db redis opensearch varnish

                # Start only the services
                docker compose up -d nginx php db redis opensearch varnish

                echo ""
                echo "=== CONTAINER STATUS ==="
                docker compose ps
                '''
            }
        }

        // ────────────────────────────────────────────────────────────────────
        stage('Wait for Services') {
        // ────────────────────────────────────────────────────────────────────
            steps {
                sh '''
                set -e

                echo "=== WAITING FOR MYSQL ==="
                RETRIES=30
                COUNT=0
                until docker compose exec -T db mysqladmin ping -h localhost --silent 2>/dev/null; do
                    COUNT=$((COUNT+1))
                    if [ $COUNT -ge $RETRIES ]; then
                        echo "ERROR: MySQL did not become ready in time"
                        docker compose logs db
                        exit 1
                    fi
                    echo "  MySQL not ready yet (attempt $COUNT/$RETRIES)..."
                    sleep 5
                done
                echo "OK: MySQL is ready."

                echo "=== WAITING FOR OPENSEARCH ==="
                RETRIES=40
                COUNT=0
                until docker compose exec -T php curl -sf http://opensearch:9200/_cluster/health > /dev/null 2>&1; do
                    COUNT=$((COUNT+1))
                    if [ $COUNT -ge $RETRIES ]; then
                        echo "ERROR: OpenSearch did not become ready in time"
                        docker compose logs opensearch
                        exit 1
                    fi
                    echo "  OpenSearch not ready yet (attempt $COUNT/$RETRIES)..."
                    sleep 5
                done
                echo "OK: OpenSearch is ready."

                echo "=== WAITING FOR VARNISH ==="
                RETRIES=10
                COUNT=0
                until docker compose exec -T nginx curl -sf http://varnish/health > /dev/null 2>&1; do
                    COUNT=$((COUNT+1))
                    if [ $COUNT -ge $RETRIES ]; then
                        echo "ERROR: Varnish did not become ready in time"
                        docker compose logs varnish
                        exit 1
                    fi
                    echo "  Varnish not ready yet (attempt $COUNT/$RETRIES)..."
                    sleep 2
                done
                echo "OK: Varnish is ready."
                '''
            }
        }

        // ────────────────────────────────────────────────────────────────────
        stage('Composer Install') {
        // The workspace magento/ is bind-mounted into the PHP container at
        // /var/www/html. Composer installs vendor/ directly into the workspace
        // — no copying needed, changes are immediately visible in the container.
        // ────────────────────────────────────────────────────────────────────
            steps {
                sh '''
                set -e
                echo "=== COMPOSER INSTALL ==="

                # Ensure writable dirs exist and are owned by www-data (33:33)
                PHP=$(docker compose ps -q php)
                docker exec --user root "${PHP}" bash -c "
                    mkdir -p /var/www/html/var/cache \
                             /var/www/html/var/page_cache \
                             /var/www/html/var/session \
                             /var/www/html/var/log \
                             /var/www/html/generated \
                             /var/www/html/pub/static \
                             /var/www/html/pub/media && \
                    chown -R www-data:www-data /var/www/html && \
                    chmod -R ug+rw \
                        /var/www/html/var \
                        /var/www/html/generated \
                        /var/www/html/pub/static \
                        /var/www/html/pub/media
                "

                docker compose exec -T php bash -c "
                    set -e
                    cd /var/www/html
                    export COMPOSER_MEMORY_LIMIT=-1
                    composer install --no-interaction --prefer-dist --no-progress --optimize-autoloader
                "
                '''
            }
        }

        // ────────────────────────────────────────────────────────────────────
        stage('Magento Setup & Build') {
        // Enforces correct execution order:
        // 1. DI compile
        // 2. Setup upgrade (--keep-generated)
        // 3. Static content deploy
        // 4. Cache flush
        // ────────────────────────────────────────────────────────────────────
            steps {
                sh '''
                set -e
                echo "=== MAGENTO SETUP & BUILD ==="
                docker compose exec -T php bash -c "
                    set -e
                    cd /var/www/html

                    echo '-- Clearing stale generated code and all caches --'
                    rm -rf generated/* \
                           var/cache/* \
                           var/page_cache/* \
                           var/view_preprocessed/* \
                           var/di/* \
                           var/generation/*

                    if [ ! -f app/etc/env.php ]; then
                        echo 'No env.php — running fresh Magento install first...'
                        php -d memory_limit=-1 bin/magento setup:install \
                            --base-url=https://localhost \
                            --db-host=db \
                            --db-name=magento \
                            --db-user=root \
                            --db-password=root \
                            --admin-firstname=Admin \
                            --admin-lastname=User \
                            --admin-user=admin \
                            --admin-password=Admin123@ \
                            --admin-email=admin@example.com \
                            --language=en_US \
                            --currency=USD \
                            --timezone=America/Chicago \
                            --use-rewrites=1 \
                            --search-engine=opensearch \
                            --opensearch-host=opensearch \
                            --opensearch-port=9200 \
                            --no-interaction
                    fi

                    echo '-- Configuring Infrastructure (Redis, OpenSearch, Varnish) --'
                    php bin/magento setup:config:set --cache-backend=redis --cache-backend-redis-server=redis --cache-backend-redis-port=6379 --cache-backend-redis-db=0 --no-interaction || true
                    php bin/magento setup:config:set --session-save=redis --session-save-redis-host=redis --session-save-redis-port=6379 --session-save-redis-log-level=4 --session-save-redis-db=2 --no-interaction || true
                    php bin/magento config:set catalog/search/engine opensearch || true
                    php bin/magento config:set catalog/search/opensearch_server_hostname opensearch || true
                    php bin/magento config:set system/full_page_cache/caching_application 2 || true
                    php bin/magento config:set system/full_page_cache/varnish/backend_host nginx || true
                    php bin/magento config:set system/full_page_cache/varnish/backend_port 8080 || true

                    echo '-- Deploying Sample Data --'
                    php -d memory_limit=-1 bin/magento sampledata:deploy --no-interaction || echo "WARNING: Sample data deployment failed (possibly due to missing auth.json credentials). Continuing..."

                    echo '-- 1. DI Compile --'
                    php -d memory_limit=-1 bin/magento setup:di:compile

                    echo '-- 2. Setup Upgrade --'
                    php -d memory_limit=-1 bin/magento setup:upgrade --keep-generated --no-interaction

                    echo '-- 3. Static Content Deploy --'
                    php -d memory_limit=-1 bin/magento setup:static-content:deploy -f en_US

                    echo '-- 4. Cache flush --'
                    php bin/magento cache:flush
                "
                '''
            }
        }
        // ────────────────────────────────────────────────────────────────────
        stage('Verify') {
        // ────────────────────────────────────────────────────────────────────
            steps {
                sh '''
                set -e
                echo "=== VERIFICATION ==="
                docker compose ps

                echo ""
                echo "--- Nginx reachability ---"
                docker compose exec -T php curl -sf --max-time 10 http://nginx/health \
                    && echo "✅ Nginx is reachable" \
                    || echo "⚠️  Nginx health check failed (check logs)"

                echo ""
                echo "--- Magento version ---"
                docker compose exec -T php php bin/magento --version

                echo ""
                echo "--- Magento module status ---"
                docker compose exec -T php php bin/magento module:status | head -20

                echo ""
                echo "--- Container logs (last 15 lines) ---"
                docker compose logs --tail=15 nginx
                docker compose logs --tail=15 php
                '''
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline SUCCEEDED — Magento is deployed and running.'
            echo "   Storefront : http://localhost:8080"
            echo "   Jenkins    : http://localhost:8082"
        }
        failure {
            sh '''
            echo "❌ Pipeline FAILED — collecting diagnostics..."
            echo ""
            echo "=== Container status ==="
            docker compose ps || true

            echo ""
            echo "=== Nginx logs ==="
            docker compose logs --tail=50 nginx || true

            echo ""
            echo "=== PHP logs ==="
            docker compose logs --tail=50 php || true

            echo ""
            echo "=== MySQL logs ==="
            docker compose logs --tail=30 db || true

            echo ""
            echo "=== OpenSearch logs ==="
            docker compose logs --tail=30 opensearch || true

            echo ""
            echo "=== Workspace files ==="
            ls -la || true
            ls -la magento/ 2>/dev/null | head -20 || true
            '''
        }
        always {
            echo 'Pipeline complete.'
        }
    }
}
