pipeline {
    agent any

    options {
        timeout(time: 40, unit: 'MINUTES')
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Abhiabhi1019/magento-project-local.git'
            }
        }

        stage('Build & Start Containers') {
            steps {
                sh '''
                docker compose down || true
                docker compose build
                docker compose up -d
                docker compose ps
                '''
            }
        }

        stage('Wait for Services') {
            steps {
                sh '''
                echo "Waiting for services..."

                sleep 60

                echo "Checking DB..."
                docker compose exec -T db mysqladmin ping -h "localhost" || true

                echo "Checking OpenSearch..."
                docker compose exec -T php curl -s http://opensearch:9200 || true
                '''
            }
        }

        stage('Check Magento Files') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                echo 'Magento files:'
                ls -la /var/www/html
                "
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html

                echo 'Running composer install...'
                composer install || true
                "
                '''
            }
        }

        stage('Fix Permissions') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html &&
                chmod -R 777 var generated pub/static pub/media || true
                "
                '''
            }
        }

        stage('Magento Install') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html

                if [ ! -f app/etc/env.php ]; then
                    echo 'Installing Magento...'

                    php -d memory_limit=2G bin/magento setup:install \
                    --base-url=http://localhost:8080 \
                    --db-host=db \
                    --db-name=magento \
                    --db-user=root \
                    --db-password=root \
                    --admin-firstname=admin \
                    --admin-lastname=admin \
                    --admin-email=admin@example.com \
                    --admin-user=admin \
                    --admin-password=Admin123@ \
                    --language=en_US \
                    --currency=USD \
                    --timezone=Asia/Kolkata \
                    --use-rewrites=1 \
                    --search-engine=opensearch \
                    --opensearch-host=opensearch \
                    --opensearch-port=9200 || true
                else
                    echo "Magento already installed"
                fi
                "
                '''
            }
        }

        stage('Deploy Magento') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html &&
                php -d memory_limit=2G bin/magento setup:upgrade || true
                php -d memory_limit=2G bin/magento cache:flush || true
                "
                '''
            }
        }

        stage('Logs') {
            steps {
                sh 'docker compose logs --tail=100 || true'
            }
        }

        stage('Verify') {
            steps {
                sh 'docker ps'
            }
        }
    }
}
