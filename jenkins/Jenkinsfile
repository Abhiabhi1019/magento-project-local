pipeline {
    agent any

    options {
        timeout(time: 40, unit: 'MINUTES')
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Abhiabhi1019/magento-project-local.git'
            }
        }

        stage('Build & Start Containers') {
            steps {
                sh '''
                docker compose down || true
                docker compose build
                docker compose up -d
                docker compose ps
                '''
            }
        }

        stage('Wait for Services') {
            steps {
                sh 'sleep 60'
            }
        }

        stage('Debug Magento Path') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                echo 'Checking Magento files...'
                cd /var/www/html
                ls -la
                "
                '''
            }
        }

        stage('Magento Install') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html

                if [ ! -f app/etc/env.php ]; then
                    echo 'Installing Magento...'

                    composer install || true

                    php bin/magento setup:install \
                    --base-url=http://localhost:8080 \
                    --db-host=db \
                    --db-name=magento \
                    --db-user=root \
                    --db-password=root \
                    --admin-firstname=admin \
                    --admin-lastname=admin \
                    --admin-email=admin@example.com \
                    --admin-user=admin \
                    --admin-password=Admin123@ \
                    --language=en_US \
                    --currency=USD \
                    --timezone=Asia/Kolkata \
                    --use-rewrites=1 || true
                else
                    echo 'Already installed'
                fi
                "
                '''
            }
        }

        stage('Deploy Magento') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html

                php bin/magento setup:upgrade || true
                php bin/magento cache:flush || true
                "
                '''
            }
        }

        stage('Logs') {
            steps {
                sh 'docker compose logs --tail=50'
            }
        }

        stage('Verify') {
            steps {
                sh 'docker ps'
            }
        }
    }
}
