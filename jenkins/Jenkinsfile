pipeline {
    agent any

    options {
        timeout(time: 40, unit: 'MINUTES')
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Abhiabhi1019/magento-project-local.git'
            }
        }

        stage('Debug') {
            steps {
                sh '''
                echo "===== DEBUG ====="
                pwd
                ls -la
                ls docker/nginx/
                ls docker-compose.yml
                '''
            }
        }

        stage('Docker Check') {
            steps {
                sh '''
                docker --version
                docker compose version
                '''
            }
        }

        stage('Build & Start Containers') {
            steps {
                sh '''
                docker compose down || true
                docker compose build
                docker compose up -d
                docker compose ps
                '''
            }
        }

        stage('Wait for Services') {
            steps {
                sh '''
                echo "Waiting for DB & OpenSearch..."
                sleep 60
                '''
            }
        }

        stage('Check Containers Running') {
            steps {
                sh '''
                echo "Checking containers..."
                docker compose ps
                '''
            }
        }

        stage('Magento Install') {
            steps {
                sh '''
                echo "Running Magento install..."

                docker compose exec -T php bash -c "
                cd /var/www/html || exit 1

                ls -la

                if [ ! -f app/etc/env.php ]; then
                    echo 'Installing Magento...'

                    composer install || exit 1

                    php bin/magento setup:install \
                    --base-url=http://localhost:8080 \
                    --db-host=db \
                    --db-name=magento \
                    --db-user=root \
                    --db-password=root \
                    --admin-firstname=admin \
                    --admin-lastname=admin \
                    --admin-email=admin@example.com \
                    --admin-user=admin \
                    --admin-password=Admin123@ \
                    --language=en_US \
                    --currency=USD \
                    --timezone=Asia/Kolkata \
                    --use-rewrites=1 || exit 1

                else
                    echo 'Magento already installed'
                fi
                "
                '''
            }
        }

        stage('Deploy Magento') {
            steps {
                sh '''
                echo "Deploying Magento..."

                docker compose exec -T php bash -c "
                cd /var/www/html || exit 1

                php bin/magento setup:upgrade || exit 1
                php bin/magento setup:di:compile || exit 1
                php bin/magento setup:static-content:deploy -f || exit 1
                php bin/magento cache:flush || exit 1
                "
                '''
            }
        }

        stage('Logs (if failure)') {
            steps {
                sh '''
                echo "==== CONTAINER LOGS ===="
                docker compose logs --tail=50
                '''
            }
        }

        stage('Verify') {
            steps {
                sh 'docker ps'
            }
        }
    }
}
