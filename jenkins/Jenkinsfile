pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/Abhiabhi1019/magento-project-local.git'
            }
        }

        stage('Set Workspace') {
            steps {
                sh '''
                echo "Workspace:"
                pwd
                ls -la
                '''
            }
        }

        stage('Build Containers') {
            steps {
                sh '''
                docker compose --project-directory $(pwd) down || true
                docker compose --project-directory $(pwd) up -d --build
                '''
            }
        }

        stage('Verify Files Inside Container') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                echo 'Inside container:'
                pwd
                ls -la /var/www/html
                "
                '''
            }
        }

        stage('Composer Install') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html

                if [ ! -f composer.json ]; then
                    echo 'ERROR: composer.json missing!'
                    exit 1
                fi

                composer install
                "
                '''
            }
        }
    }
}
