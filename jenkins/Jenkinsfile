pipeline {
    agent any

    options {
        timeout(time: 40, unit: 'MINUTES')
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Abhiabhi1019/magento-project-local.git'
            }
        }

        stage('Debug Workspace') {
            steps {
                sh '''
                echo "===== WORKSPACE ====="
                pwd
                ls -la
                echo "===== MAGENTO FOLDER ====="
                ls -la magento || echo "No magento folder"
                '''
            }
        }

        stage('Build & Start Containers') {
            steps {
                sh '''
                docker compose down || true
                docker compose build
                docker compose up -d
                '''
            }
        }

        stage('Verify Magento Files') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                echo 'Checking Magento files...'
                ls -la /var/www/html
                "
                '''
            }
        }

        stage('Wait for Services') {
            steps {
                sh 'sleep 60'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html &&
                test -f composer.json || (echo 'composer.json missing!' && exit 1)
                composer install
                "
                '''
            }
        }

        stage('Magento Install') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html &&

                if [ ! -f app/etc/env.php ]; then
                    php -d memory_limit=2G bin/magento setup:install \
                    --base-url=http://localhost:8080 \
                    --db-host=db \
                    --db-name=magento \
                    --db-user=root \
                    --db-password=root \
                    --admin-firstname=admin \
                    --admin-lastname=admin \
                    --admin-email=admin@example.com \
                    --admin-user=admin \
                    --admin-password=Admin123@ \
                    --language=en_US \
                    --currency=USD \
                    --timezone=Asia/Kolkata \
                    --use-rewrites=1 \
                    --search-engine=opensearch \
                    --opensearch-host=opensearch \
                    --opensearch-port=9200
                else
                    echo "Magento already installed"
                fi
                "
                '''
            }
        }

        stage('Deploy Magento') {
            steps {
                sh '''
                docker compose exec -T php bash -c "
                cd /var/www/html &&
                php -d memory_limit=2G bin/magento setup:upgrade &&
                php -d memory_limit=2G bin/magento cache:flush
                "
                '''
            }
        }

        stage('Logs') {
            steps {
                sh 'docker compose logs --tail=100'
            }
        }

        stage('Verify') {
            steps {
                sh 'docker ps'
            }
        }
    }
}
