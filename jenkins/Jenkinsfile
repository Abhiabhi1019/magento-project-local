pipeline {
    agent any

    options {
        timeout(time: 50, unit: 'MINUTES')
    }

    environment {
        COMPOSE_PROJECT_NAME = "magento-project-local"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Abhiabhi1019/magento-project-local.git'
            }
        }

        stage('Debug Workspace') {
            steps {
                sh '''
                echo "=== WORKSPACE ==="
                pwd
                ls -la

                echo "=== CHECK NGINX CONFIG ==="
                ls -la docker/nginx

                echo "=== CHECK COMPOSE FILE ==="
                ls -la docker-compose.yml
                '''
            }
        }

        stage('Build & Start Containers') {
            steps {
                sh '''
                echo "=== BUILD ==="
                pwd

                docker compose -f docker-compose.yml down || true
                docker compose -f docker-compose.yml up -d --build || docker compose -f docker-compose.yml up -d
                docker compose -f docker-compose.yml ps
                '''
            }
        }

        stage('Verify Mount (VERY IMPORTANT)') {
            steps {
                sh '''
                echo "=== VERIFY MOUNT ==="
                docker compose -f docker-compose.yml exec -T php ls -la /var/www/html
                '''
            }
        }

        stage('Wait for MySQL') {
            steps {
                sh '''
                echo "=== WAIT MYSQL ==="

                until docker compose -f docker-compose.yml exec -T db mysqladmin ping -h "localhost" --silent; do
                    echo "Waiting for MySQL..."
                    sleep 5
                done

                echo "MySQL is ready ✅"
                '''
            }
        }

        stage('Wait for OpenSearch') {
            steps {
                sh '''
                echo "=== WAIT OPENSEARCH ==="

                until docker compose -f docker-compose.yml exec -T php curl -s http://opensearch:9200 > /dev/null; do
                    echo "Waiting for OpenSearch..."
                    sleep 5
                done

                echo "OpenSearch is ready ✅"
                '''
            }
        }

        stage('Fix Permissions') {
            steps {
                sh '''
                echo "=== FIX PERMISSIONS ==="

                docker compose -f docker-compose.yml exec -T php bash -c "
                cd /var/www/html
                mkdir -p var generated pub/static pub/media
                chmod -R 777 var generated pub/static pub/media || true
                "
                '''
            }
        }

        stage('Composer Install') {
            steps {
                sh '''
                echo "=== COMPOSER INSTALL ==="

                docker compose -f docker-compose.yml exec -T php bash -c "
                cd /var/www/html

                if [ ! -f composer.json ]; then
                    echo 'ERROR: composer.json missing!'
                    exit 1
                fi

                if [ ! -d vendor ]; then
                    composer install --no-interaction --prefer-dist
                else
                    echo 'Vendor exists, skipping'
                fi
                "
                '''
            }
        }

        stage('Magento Install (First Time Only)') {
            steps {
                sh '''
                echo "=== MAGENTO INSTALL ==="

                docker compose -f docker-compose.yml exec -T php bash -c "
                cd /var/www/html

                if [ ! -f app/etc/env.php ]; then
                    php -d memory_limit=2G bin/magento setup:install \
                    --base-url=http://localhost:8080 \
                    --db-host=db \
                    --db-name=magento \
                    --db-user=root \
                    --db-password=root \
                    --admin-firstname=admin \
                    --admin-lastname=admin \
                    --admin-email=admin@example.com \
                    --admin-user=admin \
                    --admin-password=Admin123@ \
                    --language=en_US \
                    --currency=USD \
                    --timezone=Asia/Kolkata \
                    --use-rewrites=1 \
                    --search-engine=opensearch \
                    --opensearch-host=opensearch \
                    --opensearch-port=9200 \
                    --cleanup-database
                else
                    echo "Magento already installed"
                fi
                "
                '''
            }
        }

        stage('Deploy Magento') {
            steps {
                sh '''
                echo "=== DEPLOY ==="

                docker compose -f docker-compose.yml exec -T php bash -c "
                cd /var/www/html
                php -d memory_limit=2G bin/magento setup:upgrade || true
                php -d memory_limit=2G bin/magento cache:flush || true
                "
                '''
            }
        }

        stage('Logs') {
            steps {
                sh '''
                echo "=== LOGS ==="
                docker compose -f docker-compose.yml logs --tail=100
                '''
            }
        }

        stage('Verify') {
            steps {
                sh '''
                echo "=== FINAL STATUS ==="
                docker ps
                '''
            }
        }
    }
}
